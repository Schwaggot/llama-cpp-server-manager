#!/usr/bin/env bash
set -euo pipefail

PROFILES_DIR="/var/lib/llama-cpp/profiles"
ACTIVE_LINK="$PROFILES_DIR/active.conf"

get_active() {
    if [[ -L "$ACTIVE_LINK" ]]; then
        readlink -f "$ACTIVE_LINK"
    fi
}

# Extract a variable from a profile without executing arbitrary code.
# Usage: profile_var <file> <VAR_NAME>
profile_var() {
    local file="$1" var="$2"
    # Last assignment wins; strip surrounding quotes.
    awk -v v="$var" '
        $0 ~ "^[[:space:]]*"v"=" {
            sub("^[[:space:]]*"v"=", "")
            gsub(/^["'\''"]|["'\''"][[:space:]]*$/, "")
            val = $0
        }
        END { print val }
    ' "$file"
}

# Echo a list of missing files for a profile (one per line). Empty = all present.
profile_missing_files() {
    local file="$1"
    local model mmproj draft
    model="$(profile_var "$file" MODEL_PATH)"
    mmproj="$(profile_var "$file" MMPROJ_PATH)"
    draft="$(profile_var "$file" MODEL_DRAFT_PATH)"
    if [[ -z "$model" || ! -f "$model" ]]; then
        echo "${model:-<MODEL_PATH unset>}"
    fi
    if [[ -n "$mmproj" && ! -f "$mmproj" ]]; then
        echo "$mmproj"
    fi
    if [[ -n "$draft" && ! -f "$draft" ]]; then
        echo "$draft"
    fi
}

profile_is_available() {
    [[ -z "$(profile_missing_files "$1")" ]]
}

list_profiles() {
    local active
    active="$(get_active)"
    echo "Available profiles ([x] = model files present, [ ] = missing):"
    for f in "$PROFILES_DIR"/*.conf; do
        [[ "$(basename "$f")" == "active.conf" ]] && continue
        local name marker active_marker
        name="$(basename "$f" .conf)"
        if profile_is_available "$f"; then
            marker="[x]"
        else
            marker="[ ]"
        fi
        if [[ "$(readlink -f "$f")" == "$active" ]]; then
            active_marker=" (active)"
        else
            active_marker=""
        fi
        echo "  $marker $name$active_marker"
    done
}

switch_to() {
    local profile_name="$1"
    local profile_file="$PROFILES_DIR/$profile_name.conf"

    if [[ ! -f "$profile_file" ]]; then
        echo "ERROR: Profile '$profile_name' not found at $profile_file" >&2
        list_profiles >&2
        exit 1
    fi

    local missing
    missing="$(profile_missing_files "$profile_file")"
    if [[ -n "$missing" ]]; then
        echo "ERROR: Profile '$profile_name' references files that do not exist:" >&2
        while IFS= read -r path; do
            echo "  - $path" >&2
        done <<<"$missing"
        echo "Refusing to switch. Download the missing GGUF(s) and try again." >&2
        exit 1
    fi

    ln -sfn "$profile_file" "$ACTIVE_LINK"
    echo "Switched to: $profile_name"
}

restart_service() {
    echo "Restarting llama-cpp service..."
    systemctl restart llama-cpp
    echo "Done. Check status: systemctl status llama-cpp"
}

interactive_select() {
    local profiles=()
    local active
    active="$(get_active)"

    for f in "$PROFILES_DIR"/*.conf; do
        [[ "$(basename "$f")" == "active.conf" ]] && continue
        profile_is_available "$f" || continue
        profiles+=("$(basename "$f" .conf)")
    done

    if [[ ${#profiles[@]} -eq 0 ]]; then
        echo "No profiles with all required model files present in $PROFILES_DIR." >&2
        echo "Run 'llama-switch --list' to see every profile and what's missing." >&2
        exit 1
    fi

    # Build whiptail radiolist entries
    local items=()
    for name in "${profiles[@]}"; do
        local file="$PROFILES_DIR/$name.conf"
        local desc
        desc="$(grep -m1 '^#' "$file" | sed 's/^# *//' || echo "$name")"
        if [[ "$(readlink -f "$file")" == "$active" ]]; then
            items+=("$name" "$desc" "ON")
        else
            items+=("$name" "$desc" "OFF")
        fi
    done

    local choice
    choice=$(whiptail --title "llama-switch" \
        --radiolist "Select a model profile to activate:\n\nOnly profiles with all required model files present are shown.\nUse arrow keys to move, space to select, enter to confirm." \
        20 70 ${#profiles[@]} \
        "${items[@]}" \
        3>&1 1>&2 2>&3) || { echo "Cancelled."; exit 0; }

    if [[ -z "$choice" ]]; then
        echo "No selection made."
        exit 0
    fi

    switch_to "$choice"

    if whiptail --title "Restart service?" \
        --yesno "Restart llama-cpp service now?" \
        8 40 3>&1 1>&2 2>&3; then
        restart_service
    fi
}

# --- main ---

if [[ $# -eq 0 ]]; then
    interactive_select
    exit 0
fi

case "${1:-}" in
    --list|-l)
        list_profiles
        ;;
    --help|-h)
        echo "Usage: llama-switch [profile-name] [--restart]"
        echo "       llama-switch                   Interactive picker (only profiles whose"
        echo "                                      model files are present on disk)"
        echo "       llama-switch --list            List every profile, marking which are"
        echo "                                      backed by files on disk ([x]) and which"
        echo "                                      are missing GGUFs ([ ])"
        echo "       llama-switch <name>            Switch to profile (fails if files missing)"
        echo "       llama-switch <name> --restart  Switch and restart the service"
        ;;
    *)
        switch_to "$1"
        if [[ "${2:-}" == "--restart" ]]; then
            restart_service
        fi
        ;;
esac
